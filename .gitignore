# [Template] VisualStudio
## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPS/
[Release]/
[Release]PS/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Log]/

# MSTest ResolveAssemblyReference cache
*.cache

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
# except build/, which is used as an MSBuild target.
!**/packages/build/
# Uncomment if using NuGet Share to share packages between projects
# !**/packages/

# SQLite databases
*.db
*.db-journal
*.db-wal
*.db-shm

# Node.js
node_modules/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# VS Code
.vscode/
.history/
