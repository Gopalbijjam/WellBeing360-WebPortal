{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "SuperSecretWellBeing360SigningKey2026!",
    "Issuer": "WellBeing360",
    "Audience": "WellBeing360Client"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-public-login-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/login"
        }
      },
      "auth-public-register-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/register"
        }
      },
      "auth-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "benefits-route": {
        "ClusterId": "benefits-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/benefits/{**catch-all}"
        }
      },
      "wellness-route": {
        "ClusterId": "wellness-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/wellness/{**catch-all}"
        }
      },
      "rewards-route": {
        "ClusterId": "rewards-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/rewards/{**catch-all}"
        }
      },
      "reports-route": {
        "ClusterId": "rewards-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/reports/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "benefits-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "wellness-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "rewards-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004/"
          }
        }
      }
    }
  }
}
